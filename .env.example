# ====================================================
# Capacity Tool — Configuration Environnement
# ====================================================
# ⚠️ NE JAMAIS committer ce fichier avec les vraies valeurs
# Copier en .env.local pour le développement local

# ─── Supabase ──────────────────────────────────────
# URL du projet Supabase (ex: https://xxxx.supabase.co)
SUPABASE_URL=your_supabase_url

# Clé publique Supabase (visible dans le navigateur)
SUPABASE_ANON_KEY=your_supabase_anon_key

# Clé secrète JWT Supabase (SERVEUR UNIQUEMENT — Vercel)
# À récupérer depuis Supabase → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret

# ─── LLM Configuration ─────────────────────────────
# Fournisseur LLM : openai | anthropic | custom
LLM_PROVIDER=openai

# Clé API du fournisseur (stockée dans Vercel, jamais en .env local)
# Pour OpenAI : sk-...
# Pour Anthropic : sk-ant-...
LLM_API_KEY=your_llm_api_key

# URL personnalisée LLM (uniquement si LLM_PROVIDER=custom)
# Doit être HTTPS et dans les domaines autorisés
LLM_CUSTOM_URL=

# ─── Vercel Deployment ────────────────────────────
# URL de production (pour CORS et validation)
# Exemple: https://capacity-tool.vercel.app
PRODUCTION_URL=your_production_url

# URL de preview Vercel (auto-générée, pour le CORS en preview)
VERCEL_URL=

# ====================================================
# NOTES DE SÉCURITÉ
# ====================================================
# 1. SUPABASE_JWT_SECRET est SENSIBLE — ne jamais le mettre en .env.local
#    Le configurer uniquement dans Vercel → Settings → Environment Variables
#
# 2. LLM_API_KEY doit aussi être en Vercel uniquement (jamais en .env.local)
#
# 3. Pour développement local:
#    - Copier ce fichier en .env.local
#    - Ajouter .env.local au .gitignore
#    - Remplir SUPABASE_URL et SUPABASE_ANON_KEY uniquement
#    - Tester WITHOUT LLM_API_KEY (il sera demandé à l'utilisateur)
#
# 4. Pour déploiement Vercel:
#    - Aller à Settings → Environment Variables
#    - Ajouter TOUTES les variables ci-dessus
#    - Ne PAS les committer dans .env
